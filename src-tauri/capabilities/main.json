{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Core capabilities for the BossPatcher launcher webview",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "log:default",
    "allow-app-exit",
    "allow-call-alias",
    "allow-cancel-patch",
    "allow-get-status",
    "allow-patch-files"
  ],
  "remote": {
    "urls": ["http://localhost:*", "http://127.0.0.1:*", "https://*"]
  }
}
